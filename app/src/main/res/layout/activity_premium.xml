<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.Premium"
    android:background="@color/background">

    <TextView
        android:id="@+id/tv_premium"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/nunito_black"
        android:text="CÁ VÀNG NOTE PREMIUM"
        android:textColor="@color/text"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </TextView>

    <Button
        android:id="@+id/btn_close"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="28dp"
        android:background="@drawable/ic_close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </Button>

    <ImageView
        android:id="@+id/img_premium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_premium"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/tv_premium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </ImageView>
    
    <TextView
        android:id="@+id/tv_slogan"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_black"
        android:textSize="24dp"
        android:textColor="@color/text"
        android:textAlignment="center"
        android:text="Bắt đầu sử dụng ứng dụng với nhiều tiện ích nâng cấp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/img_premium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </TextView>

    <ImageView
        android:id="@+id/imv_check_1"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/ic_check"
        android:layout_marginTop="25dp"
        android:layout_marginLeft="30dp"
        app:layout_constraintTop_toBottomOf="@id/tv_slogan"
        app:layout_constraintStart_toStartOf="parent">
    </ImageView>
    <TextView
        android:id="@+id/tv_check_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_black"
        android:textColor="@color/text"
        android:textSize="16sp"
        android:text="Lưu trữ ghi chú không giới hạn"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@id/tv_slogan"
        app:layout_constraintStart_toEndOf="@id/imv_check_1">
    </TextView>

    <ImageView
        android:id="@+id/imv_check_2"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/ic_check"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="30dp"
        app:layout_constraintTop_toBottomOf="@id/imv_check_1"
        app:layout_constraintStart_toStartOf="parent">
    </ImageView>
    <TextView
        android:id="@+id/tv_check_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_black"
        android:textColor="@color/text"
        android:textSize="16sp"
        android:text="Tạo không giới hạn dự án"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/tv_check_1"
        app:layout_constraintStart_toEndOf="@id/imv_check_2">
    </TextView>

    <ImageView
        android:id="@+id/imv_check_3"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/ic_check"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="30dp"
        app:layout_constraintTop_toBottomOf="@id/imv_check_2"
        app:layout_constraintStart_toStartOf="parent">
    </ImageView>
    <TextView
        android:id="@+id/tv_check_3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_black"
        android:textColor="@color/text"
        android:textSize="16sp"
        android:text="Lưu trữ hằng ngày"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@id/tv_check_2"
        app:layout_constraintStart_toEndOf="@id/imv_check_3">
    </TextView>

    <LinearLayout
        android:id="@+id/btn_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="2"
        android:paddingHorizontal="30dp"
        android:layout_marginTop="35dp"
        app:layout_constraintTop_toBottomOf="@id/imv_check_3"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/card_annual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_pricing_card"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hàng năm" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$36.36"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trên một năm" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_monthly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:padding="20dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_pricing_card">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hàng tháng" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$3.6" android:textSize="24sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trên một tháng" />

        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_subscribe"
        android:layout_width="320dp"
        android:layout_height="75dp"
        android:layout_marginTop="50dp"
        android:text="ĐĂNG KÝ"
        android:fontFamily="@font/nunito_black"
        android:textSize="20sp"
        android:textColor="@color/text_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_price"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@drawable/bg_rounded_corner">
    </Button>



</androidx.constraintlayout.widget.ConstraintLayout>